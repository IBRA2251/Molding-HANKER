    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet text;\nlet last_sentence;\nfor (const item of $input.all()) {\n  item.json.myNewField = 1;\n  text = item.json.body.text;\n  last_sentence = item.json.body.returnedSentence;\n}\n\nlet list_of_responses = $input.first().json.last_message.match(/[^.!?]+[.!?]+/g)?.map(s => s.trim()) ?? [];\n\nconst index = list_of_responses.indexOf(last_sentence);\nlet list_of_messages_listened;\nif (index === -1) list_of_messages_listened = [];\nlist_of_messages_listened = list_of_responses.slice(0, index+1) ?? list_of_responses.slice(0, index);\n\nreturn {text, list_of_messages_listened, last_sentence, list_of_responses};"
      },
